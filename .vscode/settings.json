{
  // Always use CMakePresets.json
  "cmake.useCMakePresets": "always",

  // Always copy compile_commands.json from the active preset
  "cmake.copyCompileCommands": "${workspaceFolder}/compile_commands.json",
  "C_Cpp.default.compileCommands": "${workspaceFolder}/compile_commands.json",

  // Shared settings (apply to both Windows + Linux)
  "C_Cpp.default.includePath": [
    "${workspaceFolder}/**"
  ],
  "cmake.ctest.testExplorerIntegrationEnabled": true,
  "C_Cpp.default.cppStandard": "gnu++20",
  "C_Cpp.default.cStandard": "gnu17",
  
  // -----------------------------
  // Linux-specific overrides
  // -----------------------------
  "linux": {
    "C_Cpp.default.compilerPath": "/usr/bin/g++-13",
    "C_Cpp.default.intelliSenseMode": "linux-gcc-x64"
  },

  // -----------------------------
  // Windows-specific overrides
  // -----------------------------
  "windows": {
    "C_Cpp.default.compilerPath": "C:/msys64/mingw64/bin/g++.exe",
    "C_Cpp.default.intelliSenseMode": "windows-gcc-x64"
  }
}
